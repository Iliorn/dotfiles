[Unit]
Description=Mount OneDrive via rclone
After=network-online.target
Wants=network-online.target

[Service]
Type=notify
ExecStartPre=/usr/bin/mkdir -p %h/OneDrive
ExecStart=/usr/bin/rclone mount onedrive: %h/OneDrive \
    --vfs-cache-mode=full \
    --vfs-cache-max-size=4G \
    --vfs-cache-max-age=168h \
    --umask=0022 \
    --log-level=INFO
ExecStop=/bin/fusermount -uz %h/OneDrive
Restart=on-failure
RestartSec=10

[Install]
WantedBy=default.target
